# Local development does NOT need this file — Vite proxies /api to localhost:4000.
#
# For production builds (Vercel / Netlify / static host), set ONE of these so the
# frontend knows where the backend API lives:
#
#   VITE_API_URL=https://your-api.onrender.com/api      # full base URL, OR
#   VITE_API_HOST=your-api.onrender.com                 # host only (→ https://…/api)
