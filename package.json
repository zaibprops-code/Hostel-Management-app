{
  "name": "hostel-management-system",
  "version": "1.0.0",
  "private": true,
  "description": "Professional, multi-hostel management platform (SaaS-ready)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace server run build && npm --workspace web run build",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "db:reset": "npm --workspace server run db:reset"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
