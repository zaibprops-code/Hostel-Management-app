DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hostel_db?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=10

# Public address of the website — used to build the link inside reset emails.
WEB_APP_URL="http://localhost:5173"

# Password-reset email (optional). Leave blank to disable email sending.
# Example for a Gmail account (see DEPLOYMENT.md → "Password-reset email"):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   MAIL_FROM="Hostel Manager <you@gmail.com>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""
